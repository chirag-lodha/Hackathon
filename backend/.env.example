# Copy this file to backend/.env and fill in your values.
# backend/.env is gitignored — your real key never gets committed.

# Goku AI agent — free key from https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Recommended: gemini-2.5-flash-lite (biggest free-tier quota, fast).
# Alternatives if you hit "quota exceeded": gemini-flash-latest, gemini-2.5-flash
GEMINI_MODEL=gemini-2.5-flash-lite
