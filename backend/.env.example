# Copy this file to backend/.env and fill in your values.
# backend/.env is gitignored — your real key never gets committed.

# Brivo AI agent — free key from https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Recommended: gemini-2.5-flash-lite (biggest free-tier quota, fast).
# Alternatives if you hit "quota exceeded": gemini-flash-latest, gemini-2.5-flash
GEMINI_MODEL=gemini-2.5-flash-lite
# Vision model used to caption every preview (high-volume — keep it on a
# high-quota model). Defaults to gemini-2.5-flash-lite.
GEMINI_CAPTION_MODEL=gemini-2.5-flash-lite
# Image-generation model ("Nano Banana") for the optional Gemini super-res
# engine. NOTE: image generation is NOT on the Gemini free tier — this only
# produces output on a key with billing enabled; otherwise it fails gracefully.
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Upscayl CLI — the built-in (default) super-res engine. These have sensible
# defaults; override only if Upscayl is installed elsewhere or you want a
# different model. Model names are the files in the models dir (e.g.
# upscayl-standard-4x, realesrgan-x4plus, remacri).
# LUMINA_UPSCAYL_BIN=/opt/Upscayl/resources/bin/upscayl-bin
# LUMINA_UPSCAYL_MODELS=/opt/Upscayl/resources/models
# LUMINA_UPSCAYL_MODEL=upscayl-standard-4x
